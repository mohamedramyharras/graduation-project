// ─── Dense Layer Forward Pass ────────────────────────────────────
void dense_forward(float* input, float* output, const float* weights,
                   const float* bias, int in_size, int out_size, bool relu) {
    for (int o = 0; o < out_size; o++) {
        float sum = bias[o];
        for (int i = 0; i < in_size; i++) {
            sum += weights[o * in_size + i] * input[i];
        }
        output[o] = relu ? max(0.0f, sum) : sum;
    }
}

// ─── Drive Actuators ─────────────────────────────────────────────
void drive_actuators(float force) {
    // Map normalized force [0, 1] to PWM [0, 255]
    int pwm = constrain((int)(force * 255.0), 0, 255);

    // All fingers driven proportionally to total grip force
    // In a more advanced version, each finger could have
    // independent force control
    analogWrite(THUMB_PIN, pwm);
    analogWrite(INDEX_PIN, pwm);
    analogWrite(MIDDLE_PIN, pwm);
    analogWrite(RING_PIN, pwm);
    analogWrite(LITTLE_PIN, pwm);
}

// ─── Bluetooth Calibration Handler ───────────────────────────────
void handle_bluetooth() {
    if (Serial1.available()) {
        String cmd = Serial1.readStringUntil('\n');
        cmd.trim();

        if (cmd.startsWith("CAL_SCALE:")) {
            cal_scale = cmd.substring(10).toFloat();
            Serial1.print("OK:SCALE=");
            Serial1.println(cal_scale);
        }
        else if (cmd.startsWith("CAL_OFFSET:")) {
            cal_offset = cmd.substring(11).toFloat();
            Serial1.print("OK:OFFSET=");
            Serial1.println(cal_offset);
        }
        else if (cmd.startsWith("FORCE_MAX:")) {
            force_max = cmd.substring(10).toFloat();
            Serial1.print("OK:FMAX=");
            Serial1.println(force_max);
        }
        else if (cmd == "STATUS") {
            Serial1.print("SCALE=");
            Serial1.print(cal_scale);
            Serial1.print(",OFFSET=");
            Serial1.print(cal_offset);
            Serial1.print(",FMAX=");
            Serial1.println(force_max);
        }
        else if (cmd == "RESET") {
            cal_scale = 1.0;
            cal_offset = 0.0;
            force_max = 1.0;
            Serial1.println("OK:RESET");
        }
    }
}
